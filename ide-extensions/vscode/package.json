{
  "name": "surrogate-1-vscode-extension",
  "displayName": "Surrogate-1 VS Code Extension",
  "description": "Provides AI assistance for Surrogate-1 in your IDE.",
  "version": "1.0.0",
  "publisher": "axentx",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onActivationEvent"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.showWelcomePage",
        "title": "Show Welcome Page"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "node ./node_modules/vscode/bin/install"
  },
  "devDependencies": {
    "typescript": "^4.5.2",
    "vscode": "^1.1.37",
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.60.0"
  },
  "dependencies": {}
}