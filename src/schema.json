{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Workflow Definition",
    "type": "object",
    "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "llm_agents": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {"type": "string"},
                    "type": {"type": "string"}
                },
                "required": ["name", "type"]
            }
        }
    },
    "required": ["name", "description", "llm_agents"]
}