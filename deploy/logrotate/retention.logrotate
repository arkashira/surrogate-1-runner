# /opt/axentx/surrogate-1/deploy/logrotate/retention.logrotate
/var/log/axentx/surrogate-1/retention.log {
  daily
  missingok
  rotate 30
  compress
  delaycompress
  notifempty
  create 640 axentx axentx
  sharedscripts
  postrotate
    systemctl reload rsyslog >/dev/null 2>&1 || true
  endscript
}