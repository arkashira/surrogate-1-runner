{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Resource Schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique name of the workflow."
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Ordered list of step identifiers to execute."
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether the workflow is active."
    }
  },
  "required": ["name", "steps"],
  "additionalProperties": false
}