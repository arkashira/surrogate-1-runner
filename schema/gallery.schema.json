{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axentx.io/surrogate-1/templates/schema/gallery.schema.json",
  "title": "Surrogate‑1 Template Gallery",
  "description": "Catalogue of all ingestion‑pattern templates shipped with Surrogate‑1.",
  "type": "object",
  "required": ["version", "lastUpdated", "templates"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the gallery schema (e.g. 1.0.0)."
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO‑8601 timestamp of the last catalogue change."
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/templateSummary" }
    }
  },

  "definitions": {
    "templateSummary": {
      "type": "object",
      "required": ["id", "name", "category", "version", "manifestPath"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Unique kebab‑case identifier (folder name)."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "category": {
          "type": "string",
          "enum": ["github", "slack", "jira", "custom"]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "manifestPath": {
          "type": "string",
          "description": "Relative path to the manifest file (e.g. \"templates/github-repo-sync/manifest.json\")."
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Other template IDs that must be present for this one to work."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}