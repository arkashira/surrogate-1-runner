{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy",
  "description": "Schema for defining LLM decision policies",
  "type": "object",
  "properties": {
    "id": {
      "description": "Unique identifier for the policy",
      "type": "string"
    },
    "version": {
      "description": "Version of the policy",
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "rules": {
      "description": "List of rules that make up the policy",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "condition": {
            "type": "object",
            "properties": {
              "expression": {"type": "string"},
              "parameters": {"type": "object"}
            },
            "required": ["expression"]
          },
          "action": {
            "type": "string",
            "enum": ["allow", "deny", "log", "alert"]
          }
        },
        "required": ["id", "condition", "action"]
      }
    },
    "metadata": {
      "description": "Additional metadata about the policy",
      "type": "object"
    }
  },
  "required": ["id", "version", "rules"]
}