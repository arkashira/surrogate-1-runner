{
  "template_name": "DVAC02 IAM Practice Environment",
  "description": "Pre-configured lab template for DVAC02 IAM domain.",
  "resources": [
    {
      "type": "aws_iam_role",
      "name": "dvac02_iam_role",
      "properties": {
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"ec2.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}"
      }
    },
    {
      "type": "aws_iam_policy",
      "name": "dvac02_iam_policy",
      "properties": {
        "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"iam:*\",\"Resource\":\"*\"}]}"
      }
    },
    {
      "type": "aws_iam_role_policy_attachment",
      "name": "dvac02_iam_role_policy_attachment",
      "properties": {
        "role": "${aws_iam_role.dvac02_iam_role.name}",
        "policy_arn": "${aws_iam_policy.dvac02_iam_policy.arn}"
      }
    }
  ]
}