{
  "template_name": "DVAC02 VPC Practice Environment",
  "description": "Pre-configured lab template for DVAC02 VPC domain.",
  "resources": [
    {
      "type": "aws_vpc",
      "name": "dvac02_vpc",
      "properties": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_support": true,
        "enable_dns_hostnames": true
      }
    },
    {
      "type": "aws_subnet",
      "name": "dvac02_subnet",
      "properties": {
        "vpc_id": "${aws_vpc.dvac02_vpc.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "us-west-2a"
      }
    },
    {
      "type": "aws_internet_gateway",
      "name": "dvac02_igw",
      "properties": {
        "vpc_id": "${aws_vpc.dvac02_vpc.id}"
      }
    }
  ]
}