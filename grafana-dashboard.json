{
  "dashboard": {
    "title": "Ingestion Metrics",
    "panels": [
      {
        "title": "Ingestion Duration",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ingestion_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(ingestion_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P50"
          }
        ]
      },
      {
        "title": "Ingestion Failures",
        "type": "singlestat",
        "targets": [
          {
            "expr": "sum(rate(ingestion_failures_total[5m]))",
            "format": "short"
          }
        ]
      }
    ]
  }
}