{
  "dashboard": {
    "id": null,
    "title": "LLM Surrogate-1 Metrics Monitoring",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "type": "graph",
        "title": "Request Latency (95th percentile)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(llm_surrogate_1_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "95th percentile",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Seconds",
            "max": null,
            "min": 0,
            "show": true
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "type": "graph",
        "title": "Error Rate",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(llm_surrogate_1_request_errors_total[5m])",
            "legendFormat": "Errors per second",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Errors per second",
            "max": null,
            "min": 0,
            "show": true
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "type": "graph",
        "title": "Usage Count",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(llm_surrogate_1_requests_total[5m])",
            "legendFormat": "Requests per second",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Requests per second",
            "max": null,
            "min": 0,
            "show": true
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
  },
  "overwrite": true
}