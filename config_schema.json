{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "dataset_name": {
      "type": "string"
    },
    "shard_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    },
    "output_path": {
      "type": "string"
    },
    "interval": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": ["dataset_name", "shard_id", "output_path"]
}