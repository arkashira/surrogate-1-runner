COLLECTOR_ENABLED=true
COLLECTOR_SERVICE_NAME=surrogate-1
COLLECTOR_VERSION_LABEL=1.0.0
COLLECTOR_SAMPLING_RATE=0.95
COLLECTOR_HEADERS_CAPTURE=Content-Type,Content-Length,User-Agent,Accept,Accept-Encoding,Accept-Language,Cache-Control,Connection
COLLECTOR_HEADERS_REDACT=Authorization,Set-Cookie,Cookie,Proxy-Authorization,X-Forwarded-For,X-Real-IP
COLLECTOR_BODY_SCHEMA_ENABLED=true
COLLECTOR_BODY_SCHEMA_MAX_DEPTH=5
COLLECTOR_BODY_SCHEMA_MAX_ITEMS=100
COLLECTOR_STORAGE_TYPE=file
COLLECTOR_STORAGE_PATH=/var/log/surrogate-1/collector
COLLECTOR_STORAGE_ROTATION_MAX_SIZE=100MB
COLLECTOR_STORAGE_ROTATION_MAX_FILES=7